Q4). Give a temporary password to patients who made their first visit.
     SELECT p.patient_id, CAST(p.patient_id AS TEXT) || CAST(LENGTH(p.last_name) AS TEXT) || CAST(strftime('%Y', p.birth_date) AS TEXT)
     AS temp_password FROM patients p JOIN (SELECT patient_id, MIN(admission_date) AS first_adm FROM admissions GROUP BY patient_id) fa
     ON p.patient_id = fa.patient_id;

